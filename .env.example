# Required: secret key for signing JWTs — use a long random string in production
MCP_JWT_SECRET=change-me-to-a-long-random-secret

# Required for management endpoints in non-dev environments
MCP_ADMIN_KEY=change-me-to-an-admin-key

# Optional overrides
MCP_JWT_ISSUER=mcp-server
MCP_JWT_ALGORITHM=HS256
MCP_DATABASE_URL=sqlite:///./skillful_mcp.db

# ----- Web UI operator auth (Wave 6a) --------------------------------
# Required when running the Web UI. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_WEBUI_SESSION_SECRET=change-me-to-a-long-random-secret

# JSON list of operators. Generate a hash with:
#   python -c "from webui.auth import hash_password; print(hash_password('your-password'))"
# Empty = nobody can log in; the app still starts.
MCP_WEBUI_OPERATORS=[]

# ----- Bundle store (Wave 5) -----------------------------------------
# MCP_BUNDLE_STORE=inline   # default
# MCP_BUNDLE_STORE=s3
# MCP_BUNDLE_S3_BUCKET=
# MCP_BUNDLE_S3_PREFIX=bundles
# MCP_BUNDLE_S3_REGION=us-east-1
# MCP_BUNDLE_S3_ENDPOINT_URL=  # for MinIO / LocalStack
