# Required: secret key for signing JWTs — use a long random string in production
MCP_JWT_SECRET=change-me-to-a-long-random-secret

# Required for management endpoints in non-dev environments
MCP_ADMIN_KEY=change-me-to-an-admin-key

# Optional overrides
MCP_JWT_ISSUER=mcp-server
MCP_JWT_ALGORITHM=HS256
MCP_DATABASE_URL=sqlite:///./skillful_mcp.db
